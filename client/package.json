{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "font": "node public/font/ttf2woff2.js",
    "lint": "eslint --ext .js,.vue src",
    "lint:fix": "eslint --ext .js,.vue src --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.1.0",
    "animejs": "3.2.1",
    "ant-design-vue": "4.2.6",
    "dayjs": "1.11.19",
    "echarts": "5.4.2",
    "element-plus": "2.3.7",
    "odometer": "0.4.8",
    "sortablejs": "1.15.0",
    "vue": "3.5.22",
    "vue-router": "4.6.3",
    "vue3-odometer": "0.1.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vitejs/plugin-vue": "6.0.1",
    "eslint": "10.4.1",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "ttf2woff2": "8.0.1",
    "vite": "7.1.7"
  },
  "lint-staged": {
    "src/**/*.{vue,js,jsx,ts,tsx}": [
